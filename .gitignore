```gitignore
# Compiled and binary files
*.pyc
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
dist/
build/
target/
.gradle/

# Editors/IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System/Environment
.DS_Store
Thumbs.db
.env
.env.local
*.env.*

# Logs and coverage
*.log
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
```